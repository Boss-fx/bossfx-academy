# ================================================================
# BossFx Academy — Environment Variables
# ================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git — it contains secrets
# ================================================================

# ---- Flutterwave (Payment Provider) ----
# Get these from: https://dashboard.flutterwave.com/settings/apis
# ⚠️  FLUTTERWAVE_SECRET_KEY is REQUIRED for payment verification!
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X

# Webhook hash — set in Flutterwave Dashboard > Settings > Webhooks
# Code accepts EITHER name (FLUTTERWAVE_WEBHOOK_HASH or FLUTTERWAVE_WEBHOOK_SECRET)
FLUTTERWAVE_WEBHOOK_HASH=your-webhook-secret-hash

# ---- Brevo (Email Provider) ----
# Get this from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Email Configuration ----
SENDER_EMAIL=hello@bossfxcademy.com
ADMIN_EMAIL=hello@bossfxcademy.com

# ---- Secure Download Token Secret ----
# Used to sign/verify Forex 101 PDF download tokens (HMAC-SHA256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Falls back to FLUTTERWAVE_SECRET_KEY if not set
DOWNLOAD_SECRET=your-random-secret-key-here

# ---- Optional: Vercel Environment ----
# NODE_ENV=production
