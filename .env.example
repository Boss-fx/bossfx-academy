# ================================================================
# BossFx Academy — Environment Variables
# ================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git — it contains secrets
# ================================================================

# ---- Flutterwave (Payment Provider) ----
# Get these from: https://dashboard.flutterwave.com/settings/apis
# ⚠️  FLUTTERWAVE_SECRET_KEY is REQUIRED for payment verification!
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X

# Webhook hash — set in Flutterwave Dashboard > Settings > Webhooks
# Code accepts EITHER name (FLUTTERWAVE_WEBHOOK_HASH or FLUTTERWAVE_WEBHOOK_SECRET)
FLUTTERWAVE_WEBHOOK_HASH=your-webhook-secret-hash

# ---- Brevo (Email Provider) ----
# Get this from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Email Configuration ----
# Sender identity for all outbound emails (must be verified in Brevo)
SENDER_EMAIL=hello@bossfxcademy.com
ADMIN_EMAIL=hello@bossfxcademy.com

# ---- Admin Dashboard ----
# Comma-separated list of emails allowed to access admin + founder dashboards
ADMIN_EMAILS=hello@bossfxcademy.com

# ---- Supabase Auth SMTP (configured in Supabase Dashboard, not here) ----
# Supabase Auth emails route through Brevo SMTP relay.
# Configure in Supabase Dashboard → Auth → SMTP Settings:
#   Host: smtp-relay.brevo.com
#   Port: 587
#   Username: [Brevo login email]
#   Password: [Brevo SMTP key from Dashboard → SMTP & API → SMTP tab]
#   Sender: hello@bossfxcademy.com / BossFx Academy

# ---- Secure Download Token Secret ----
# Used to sign/verify Forex 101 PDF download tokens (HMAC-SHA256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Falls back to FLUTTERWAVE_SECRET_KEY if not set
DOWNLOAD_SECRET=your-random-secret-key-here

# ---- Supabase (Database + Auth + Storage) ----
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci-your-service-role-key
SUPABASE_ANON_KEY=eyJhbGci-your-anon-key

# ---- Optional: Vercel Environment ----
# NODE_ENV=production
